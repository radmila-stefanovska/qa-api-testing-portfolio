  "item": [
    {
      "name": "Positive Tests",
      "item": [
        {
          "name": "POST - User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Access Token exists\", function () {\r",
                  "    pm.expect(response.accessToken).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Refresh Token exists\", function () {\r",
                  "    pm.expect(response.refreshToken).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Username is correct\", function () {\r",
                  "    pm.expect(response.username).to.eql(pm.environment.get(\"username\"));\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Email exists\", function () {\r",
                  "    pm.expect(response.email).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"accessToken\", response.accessToken);\r",
                  "pm.environment.set(\"refreshToken\", response.refreshToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"{{username}}\",\r\n  \"password\": \"{{password}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "GET - Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"User ID is 1\", function () {\r",
                  "    pm.expect(response.id).to.eql(1);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Username is emilys\", function () {\r",
                  "    pm.expect(response.username).to.eql(\"emilys\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Email exists\", function () {\r",
                  "    pm.expect(response.email).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Accessed protected user profile\", function () {\r",
                  "    pm.expect(response).to.have.property(\"firstName\");\r",
                  "    pm.expect(response).to.have.property(\"lastName\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is less than 1000ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://dummyjson.com/auth/me",
