  "item": [
    {
      "name": "GET - Products Pagination",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Limit is 10\", function () {\r",
              "    pm.expect(response.limit).to.eql(10);\r",
              "});\r",
              "\r",
              "pm.test(\"Skip is 30\", function () {\r",
              "    pm.expect(response.skip).to.eql(30);\r",
              "});\r",
              "\r",
              "pm.test(\"Products array has 10 items\", function () {\r",
              "    pm.expect(response.products).to.be.an(\"array\");\r",
              "    pm.expect(response.products.length).to.eql(10);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products?limit=10&skip=30",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "products"
          ],
          "query": [
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "skip",
              "value": "30"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET - Search Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Products array exists\", function () {\r",
              "    pm.expect(response.products).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"At least one product is returned\", function () {\r",
              "    pm.expect(response.products.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Search returned matching products\", function () {\r",
              "    response.products.forEach(product => {\r",
              "        const text = (product.title + \" \" + product.description).toLowerCase();\r",
              "        pm.expect(text).to.include(\"phone\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
