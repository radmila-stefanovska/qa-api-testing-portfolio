    {
      "name": "GET - Single Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "const schema = {\r",
              "    type: \"object\",\r",
              "\r",
              "    required: [\r",
              "        \"id\",\r",
              "        \"title\",\r",
              "        \"price\",\r",
              "        \"category\",\r",
              "        \"description\",\r",
              "        \"images\"\r",
              "    ],\r",
              "\r",
              "    properties: {\r",
              "        id: {\r",
              "            type: \"number\"\r",
              "        },\r",
              "\r",
              "        title: {\r",
              "            type: \"string\",\r",
              "            minLength: 3,\r",
              "            maxLength: 100\r",
              "        },\r",
              "\r",
              "        price: {\r",
              "            type: \"number\",\r",
              "            minimum: 0,\r",
              "            maximum: 10000\r",
              "        },\r",
              "\r",
              "        category: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "\r",
              "        description: {\r",
              "            type: \"string\"\r",
              "        },\r",
              "\r",
              "        images: {\r",
              "            type: \"array\",\r",
              "            minItems: 1,\r",
              "            items: {\r",
              "                type: \"string\",\r",
              "                format: \"uri\"\r",
              "    }\r",
              "}\r",
              "\r",
              "    }\r",
              "};\r",
              "\r",
              "pm.test(\"Response matches JSON Schema\", function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Product ID is 10\", function () {\r",
              "    pm.expect(response.id).to.eql(10);\r",
              "});\r",
              "\r",
              "pm.test(\"Title exists\", function () {\r",
              "    pm.expect(response.title).to.be.a(\"string\");\r",
              "    pm.expect(response.title.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Price is numeric\", function () {\r",
              "    pm.expect(response.price).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "pm.test(\"Category is a string\", function () {\r",
              "    pm.expect(response.category).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "pm.test(\"Content-Type is application/json\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
              "        .to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Date header exists\", function () {\r",
              "    pm.expect(pm.response.headers.has(\"Date\")).to.be.true;\r",
              "});\r",
              "\r",
              "pm.test(\"Response is compressed\", function () {\r",
              "    pm.expect(pm.response.headers.has(\"Content-Encoding\")).to.be.true;\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
